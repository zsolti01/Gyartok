<Window x:Class="Gyartok.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gyartok"
        mc:Ignorable="d"
        Title="Gyártók" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="dataG" HorizontalAlignment="Left" Height="380" Margin="10,20,0,0" VerticalAlignment="Top" Width="564" RenderTransformOrigin="-3.041,-0.8" BorderThickness="3" Background="#FF6FC3FF" BorderBrush="Black"/>
        <Button x:Name="dbSzam" Content="Darabszám" HorizontalAlignment="Left" Margin="603,20,0,0" VerticalAlignment="Top" Width="171" Height="57" Background="#FF6FC3FF" BorderBrush="Black" FontSize="26" Foreground="White" FontWeight="Bold" BorderThickness="3" Click="dbSzam_Click"/>
        <Button x:Name="lgTobb" Content="Legtöbb leányvállalat" HorizontalAlignment="Left" Margin="603,82,0,0" VerticalAlignment="Top" Width="171" Height="57" Background="#FF6FC3FF" BorderBrush="Black" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="3" Click="lgTobb_Click"/>
        <Button x:Name="exit" Content="Kilépés" HorizontalAlignment="Left" Margin="603,343,0,0" VerticalAlignment="Top" Width="171" Height="57" Background="#FFFF3C3C" BorderBrush="Black" Foreground="White" FontWeight="Bold" FontSize="26" BorderThickness="3" Click="exit_Click"/>

    </Grid>
</Window>
